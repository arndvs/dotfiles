#!/usr/bin/env bash
# ctrl — command-line interface for ctrl+shft
#
# Usage:
#   ctrl <command> [options]
#
# Run 'ctrl help' for available commands.
#
# Installation:
#   bootstrap.sh symlinks this to ~/.local/bin/ctrl automatically.
#   Manual: ln -sf ~/dotfiles/bin/ctrl ~/.local/bin/ctrl
#
# Follows repo conventions:
#   - Sources _lib.sh for green/yellow/red/detect_os
#   - set -euo pipefail
#   - Works on macOS, Linux, WSL, Git Bash

set -euo pipefail

# ── Bootstrap self-location ───────────────────────────────────────────────────
# Works whether invoked as a symlink from ~/.local/bin/ctrl or directly
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
DOTFILES="${DOTFILES:-$HOME/dotfiles}"

# Verify we can find _lib.sh — if not, the install is broken
if [[ ! -f "$DOTFILES/bin/_lib.sh" ]]; then
    echo "  ctrl: cannot find $DOTFILES/bin/_lib.sh"
    echo "  Is ~/dotfiles set up correctly? Run: bash ~/dotfiles/bin/bootstrap.sh"
    exit 1
fi

source "$DOTFILES/bin/_lib.sh"

# ── Helpers ───────────────────────────────────────────────────────────────────
# dim is not in _lib.sh — define locally
dim() { printf '\033[2m%s\033[0m\n' "$*"; }

# Graceful degradation when sheal is not installed
_require_sheal() {
    if ! command -v sheal &>/dev/null; then
        red "sheal is not installed."
        echo ""
        echo "  Install: npm install -g @liwala/sheal"
        echo "     — or: pnpm install -g @liwala/sheal  (requires pnpm setup first)"
        echo "  Then:    ctrl $CMD"
        exit 1
    fi
}

# Check if HUD is running
_hud_running() {
    local _pid_file="$DOTFILES/working/hud-daemon.pid"
    [[ -f "$_pid_file" ]] && kill -0 "$(cat "$_pid_file")" 2>/dev/null
}

# Open URL in browser (cross-platform)
_open_browser() {
    local url="$1"
    case "$(detect_os)" in
        macos)   open "$url" ;;
        windows) start "$url" 2>/dev/null || cmd.exe /c start "$url" 2>/dev/null ;;
        *)       xdg-open "$url" 2>/dev/null || echo "  Open: $url" ;;
    esac
}

# ── Version ───────────────────────────────────────────────────────────────────
CTRL_VERSION="0.1.0"

# ── Subcommand routing ────────────────────────────────────────────────────────
CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in

    # ── check ──────────────────────────────────────────────────────────────────
    check)
        green "ctrl check — validating ctrl+shft installation"
        echo ""

        _fail=0

        # Symlink integrity
        if [[ -f "$DOTFILES/bin/validate-symlinks.sh" ]]; then
            bash "$DOTFILES/bin/validate-symlinks.sh" "$@" || _fail=1
        else
            yellow "  validate-symlinks.sh not found — run: ctrl bootstrap"
            _fail=1
        fi

        echo ""

        # Env validation
        if [[ -f "$DOTFILES/bin/validate-env.sh" ]]; then
            bash "$DOTFILES/bin/validate-env.sh" "$@" || _fail=1
        else
            yellow "  validate-env.sh not found"
        fi

        echo ""
        if [[ "$_fail" -eq 0 ]]; then
            green "All checks passed."
        else
            red "Some checks failed. See above for details."
            exit 1
        fi
        ;;

    # ── bootstrap ──────────────────────────────────────────────────────────────
    bootstrap|boot)
        green "ctrl bootstrap — running bootstrap.sh $*"
        echo ""
        bash "$DOTFILES/bin/bootstrap.sh" "$@"
        ;;

    # ── sync ───────────────────────────────────────────────────────────────────
    sync)
        green "ctrl sync — pulling latest + re-bootstrapping"
        echo ""

        # Pull dotfiles
        cd "$DOTFILES"
        if git rev-parse --git-dir > /dev/null 2>&1; then
            green "Pulling ~/dotfiles..."
            git pull
        else
            yellow "~/dotfiles is not a git repo — skipping pull"
        fi

        echo ""

        # Re-bootstrap
        green "Re-bootstrapping..."
        bash "$DOTFILES/bin/bootstrap.sh"

        echo ""

        # Reload shell
        green "Done. Reload your shell to pick up any changes:"
        echo ""
        echo "  source ~/.bashrc   # bash"
        echo "  source ~/.zshrc    # zsh"
        ;;

    # ── status ─────────────────────────────────────────────────────────────────
    status)
        echo ""
        echo "  ctrl+shft status"
        echo "  ─────────────────────────────────────────────────────────"
        echo ""

        # Version
        echo "  Version:   $CTRL_VERSION"
        echo "  Dotfiles:  $DOTFILES"
        echo ""

        # Active context
        echo "  Contexts:  ${ACTIVE_CONTEXTS:-none}"
        echo "  Client:    ${ACTIVE_CLIENT:-none}"
        echo "  Project:   ${ACTIVE_PROJECT:-none}"
        echo "  IDE:       ${VSCODE_IPC_HOOK:+vscode}${CURSOR_SESSION_ID:+cursor}${VSCODE_IPC_HOOK:-${CURSOR_SESSION_ID:-terminal}}"
        echo ""

        # Quick symlink check (silent, just show result)
        if [[ -f "$DOTFILES/bin/validate-symlinks.sh" ]]; then
            if bash "$DOTFILES/bin/validate-symlinks.sh" --ci > /dev/null 2>&1; then
                green "  Symlinks:  all correct"
            else
                red   "  Symlinks:  issues detected — run: ctrl check"
            fi
        else
            yellow "  Symlinks:  validate-symlinks.sh not found"
        fi

        # HUD status (no `local` — we're at case scope, not in a function)
        _pid_file="$DOTFILES/working/hud-daemon.pid"
        if [[ -f "$_pid_file" ]] && kill -0 "$(cat "$_pid_file")" 2>/dev/null; then
            green "  HUD: running — http://localhost:${HUD_PORT:-7823}"
        else
            echo "  HUD: not running  (ctrl hud to start)"
        fi

        # sheal presence
        if command -v sheal &>/dev/null; then
            green "  sheal:     installed $(sheal --version 2>/dev/null || echo '')"
        else
            yellow "  sheal:     not installed  (npm install -g @liwala/sheal)"
        fi

        echo ""
        ;;

    # ── hud ────────────────────────────────────────────────────────────────────
    hud|dashboard|dash)
        if [[ ! -f "$DOTFILES/bin/start-hud.sh" ]]; then
            red "start-hud.sh not found. Run: ctrl bootstrap"
            exit 1
        fi

        # Route sub-subcommands
        _dash_cmd="${1:-start}"
        shift 2>/dev/null || true

        case "$_dash_cmd" in
            start|"")   bash "$DOTFILES/bin/start-hud.sh" "$@" ;;
            stop)       bash "$DOTFILES/bin/start-hud.sh" --stop "$@" ;;
            status)     bash "$DOTFILES/bin/start-hud.sh" --status "$@" ;;
            restart)    bash "$DOTFILES/bin/start-hud.sh" --restart "$@" ;;
            --fg|foreground) bash "$DOTFILES/bin/start-hud.sh" --fg "$@" ;;
            log|logs)
                _log="$DOTFILES/working/hud-daemon.log"
                if [[ ! -f "$_log" ]]; then
                    yellow "No log file found at $_log"
                    exit 0
                fi
                if [[ "${1:-}" == "-f" ]] || [[ "${1:-}" == "--follow" ]]; then
                    tail -f "$_log"
                else
                    tail -50 "$_log"
                    echo ""
                    dim "  Run 'ctrl hud logs -f' to follow"
                fi
                ;;
            events)
                _project="${1:-${ACTIVE_PROJECT:-default}}"
                _port="${HUD_PORT:-7823}"
                green "Recent events for project: $_project"
                echo ""
                # Prefer API when daemon is running, fall back to JSONL grep
                if _hud_running && command -v curl &>/dev/null; then
                    curl -s "http://localhost:$_port/api/events/$_project?limit=20" 2>/dev/null \
                        | python3 -c "
import json, sys
try:
    events = json.load(sys.stdin)
    if not events:
        print('  No events for this project.')
        sys.exit(0)
    for e in events:
        ts = e.get('time', e.get('timestamp', '')[:19])
        etype = e.get('type', '?')
        msg = e.get('message', '')
        print(f'  {ts}  [{etype:5}]  {msg}')
except:
    print('  Could not parse API response.')
" 2>/dev/null || echo "  API query failed — try: ctrl hud logs"
                else
                    _events_file="$DOTFILES/working/events.jsonl"
                    if [[ ! -f "$_events_file" ]]; then
                        yellow "No events file found."
                        exit 0
                    fi
                    grep "\"project\":\"$_project\"" "$_events_file" 2>/dev/null | tail -20 || echo "  No events for $_project"
                fi
                echo ""
                ;;
            clear)
                _project="${1:-${ACTIVE_PROJECT:-default}}"
                read -rp "  Clear events for '$_project'? [y/N]: " _confirm
                if [[ "$_confirm" =~ ^[Yy]$ ]]; then
                    _events_file="$DOTFILES/working/events.jsonl"
                    if [[ -f "$_events_file" ]]; then
                        grep -v "\"project\":\"$_project\"" "$_events_file" > "$_events_file.tmp" 2>/dev/null || true
                        mv "$_events_file.tmp" "$_events_file"
                        green "Events cleared for $_project."
                    fi
                    # Also dismiss from running daemon if active
                    if _hud_running && command -v curl &>/dev/null; then
                        _port="${HUD_PORT:-7823}"
                        curl -sX DELETE "http://localhost:$_port/api/projects/$_project" >/dev/null 2>&1 || true
                    fi
                else
                    echo "  Cancelled."
                fi
                ;;
            violations)
                _project="${1:-${ACTIVE_PROJECT:-default}}"
                _port="${HUD_PORT:-7823}"
                if ! _hud_running; then
                    yellow "HUD not running. Start it first: ctrl hud"
                    exit 1
                fi
                green "Violations for project: $_project"
                echo ""
                curl -s "http://localhost:$_port/api/violations/$_project" 2>/dev/null \
                    | python3 -c "
import json, sys
try:
    violations = json.load(sys.stdin)
    if not violations:
        print('  No violations recorded.')
        sys.exit(0)
    for v in violations:
        ts = v.get('time', v.get('timestamp', '')[:19])
        msg = v.get('message', '')
        print(f'  {ts}  {msg}')
except:
    print('  Could not parse API response.')
" 2>/dev/null || echo "  API query failed."
                echo ""
                ;;
            state)
                _port="${HUD_PORT:-7823}"
                if ! _hud_running; then
                    yellow "HUD not running. Start it first: ctrl hud"
                    exit 1
                fi
                curl -s "http://localhost:$_port/api/state" 2>/dev/null \
                    | python3 -m json.tool 2>/dev/null \
                    || echo "  Could not fetch state."
                ;;
            open)
                _port="${HUD_PORT:-7823}"
                _url="http://localhost:$_port"
                if _hud_running; then
                    _open_browser "$_url"
                else
                    yellow "HUD not running. Start it first: ctrl hud"
                fi
                ;;
            url)
                echo "http://localhost:${HUD_PORT:-7823}"
                ;;
            *)
                red "Unknown hud subcommand: $_dash_cmd"
                echo "  Usage: ctrl hud [start|stop|status|restart|logs|events|clear|violations|state|open|url]"
                exit 1
                ;;
        esac
        ;;

    # ── bridge ─────────────────────────────────────────────────────────────────
    bridge)
        _bridge_root="${BRIDGE_ROOT:-$HOME/bridge}"
        _bridge_cmd="${1:-status}"
        shift 2>/dev/null || true

        case "$_bridge_cmd" in
            start)
                systemctl --user start bridge-webhook.service
                _wcount="${WORKER_COUNT:-1}"
                for _i in $(seq 1 "$_wcount"); do
                    systemctl --user start "bridge-worker@${_i}.service"
                done
                green "Bridge started ($_wcount worker$([ "$_wcount" -gt 1 ] && echo s))"
                ;;
            stop)
                systemctl --user stop 'bridge-worker@*.service' bridge-webhook.service 2>/dev/null || true
                green "Bridge stopped"
                ;;
            restart)
                systemctl --user stop 'bridge-worker@*.service' bridge-webhook.service 2>/dev/null || true
                systemctl --user start bridge-webhook.service
                _wcount="${WORKER_COUNT:-1}"
                for _i in $(seq 1 "$_wcount"); do
                    systemctl --user start "bridge-worker@${_i}.service"
                done
                green "Bridge restarted ($_wcount worker$([ "$_wcount" -gt 1 ] && echo s))"
                ;;
            status)
                echo ""
                green "Bridge status"
                echo ""
                systemctl --user status bridge-webhook.service --no-pager 2>/dev/null || yellow "  webhook: not installed"
                echo ""
                systemctl --user list-units 'bridge-worker@*.service' --no-pager 2>/dev/null || yellow "  workers: none"
                echo ""
                if [[ -f "$_bridge_root/state.db" ]]; then
                    echo "  Queue:"
                    sqlite3 "$_bridge_root/state.db" \
                        "SELECT status, COUNT(*) as count FROM jobs GROUP BY status;" 2>/dev/null || echo "  (no jobs)"
                else
                    dim "  No state.db found — bridge not installed?"
                    dim "  Run: ctrl bridge validate"
                fi
                echo ""
                ;;
            logs)
                _logfile="$_bridge_root/logs/bridge.log"
                if [[ ! -f "$_logfile" ]]; then
                    yellow "No log file found at $_logfile"
                    exit 0
                fi
                if [[ "${1:-}" == "-f" ]] || [[ "${1:-}" == "--follow" ]]; then
                    tail -f "$_logfile"
                else
                    tail -50 "$_logfile"
                    echo ""
                    dim "  Run 'ctrl bridge logs -f' to follow"
                fi
                ;;
            queue)
                if [[ ! -f "$_bridge_root/state.db" ]]; then
                    yellow "No state.db found at $_bridge_root"
                    exit 1
                fi
                sqlite3 -header -column "$_bridge_root/state.db" \
                    "SELECT id, status, repo_full_name, pr_number, iteration,
                            enqueued_at
                     FROM jobs ORDER BY id DESC LIMIT 20;"
                ;;
            workers)
                systemctl --user list-units 'bridge-worker@*.service' --no-pager 2>/dev/null || true
                if [[ -f "$_bridge_root/state.db" ]]; then
                    echo ""
                    sqlite3 -header -column "$_bridge_root/state.db" \
                        "SELECT worker_id, COUNT(*) as active
                         FROM jobs WHERE status='claimed' GROUP BY worker_id;" 2>/dev/null || true
                fi
                ;;
            workspaces)
                ls -la "$_bridge_root/workspaces/" 2>/dev/null || echo "  (none)"
                ;;
            replay)
                _job_id="${1:-}"
                if [[ -z "$_job_id" ]]; then
                    red "usage: ctrl bridge replay <job-id>"
                    exit 1
                fi
                if [[ ! -f "$_bridge_root/state.db" ]]; then
                    red "No state.db found"
                    exit 1
                fi
                sqlite3 "$_bridge_root/state.db" \
                    "UPDATE jobs SET status='queued', claimed_at=NULL,
                                     finished_at=NULL, error=NULL,
                                     worker_id=NULL
                     WHERE id=$_job_id;"
                green "Job $_job_id re-queued."
                ;;
            mint)
                if [[ -f "$DOTFILES/bin/verify-github-app-token.sh" ]]; then
                    bash "$DOTFILES/bin/verify-github-app-token.sh" "$@"
                else
                    red "verify-github-app-token.sh not found."
                    exit 1
                fi
                ;;
            validate)
                if [[ -f "$DOTFILES/bin/bridge-install.sh" ]]; then
                    bash "$DOTFILES/bin/bridge-install.sh" --validate "$@"
                else
                    red "bridge-install.sh not found. Run: ctrl bootstrap"
                    exit 1
                fi
                ;;
            url)
                echo "  Webhook endpoint: http://127.0.0.1:${BRIDGE_PORT:-8765}/webhook"
                echo "  Health check:     http://127.0.0.1:${BRIDGE_PORT:-8765}/healthz"
                dim "  Configure your reverse proxy to forward to this address."
                ;;
            --fg|foreground)
                _venv="$DOTFILES/secrets/.venv"
                if [[ ! -x "$_venv/bin/uvicorn" ]]; then
                    red "uvicorn not found in $_venv. Run: ctrl bridge validate"
                    exit 1
                fi
                cd "$DOTFILES" && "$_venv/bin/uvicorn" \
                    bridge.webhook:app --host 127.0.0.1 \
                    --port "${BRIDGE_PORT:-8765}" --reload
                ;;
            *)
                red "Unknown bridge subcommand: $_bridge_cmd"
                echo "  Usage: ctrl bridge [start|stop|restart|status|logs|queue|workers|workspaces|replay|mint|validate|url|--fg]"
                exit 1
                ;;
        esac
        ;;

    # ── sync-settings ──────────────────────────────────────────────────────────
    sync-settings)
        if [[ ! -f "$DOTFILES/bin/sync-settings.sh" ]]; then
            red "sync-settings.sh not found."
            exit 1
        fi
        green "ctrl sync-settings — merging managed VS Code settings"
        echo ""
        bash "$DOTFILES/bin/sync-settings.sh" "$@"
        ;;

    # ── verify-token ───────────────────────────────────────────────────────────
    verify-token)
        if [[ ! -f "$DOTFILES/bin/verify-github-app-token.sh" ]]; then
            red "verify-github-app-token.sh not found."
            exit 1
        fi
        green "ctrl verify-token — testing GitHub App token mint"
        echo ""
        bash "$DOTFILES/bin/verify-github-app-token.sh" "$@"
        ;;

    # ── migrate ────────────────────────────────────────────────────────────────
    migrate)
        if [[ ! -f "$DOTFILES/bin/migrate.sh" ]]; then
            red "migrate.sh not found."
            exit 1
        fi
        bash "$DOTFILES/bin/migrate.sh" "$@"
        ;;

    # ── uninstall ──────────────────────────────────────────────────────────────
    uninstall)
        if [[ ! -f "$DOTFILES/bin/uninstall.sh" ]]; then
            red "uninstall.sh not found."
            exit 1
        fi

        echo ""
        yellow "This will remove ctrl+shft symlinks and shell integration."
        yellow "Your ~/dotfiles folder will not be touched."
        echo ""
        read -rp "  Continue? [y/N]: " _confirm
        if [[ "$_confirm" =~ ^[Yy]$ ]]; then
            bash "$DOTFILES/bin/uninstall.sh" "$@"
        else
            echo "  Cancelled."
        fi
        ;;

    # ── new-client ─────────────────────────────────────────────────────────────
    new-client|client)
        if [[ ! -f "$DOTFILES/bin/new-client.sh" ]]; then
            red "new-client.sh not found."
            exit 1
        fi
        bash "$DOTFILES/bin/new-client.sh" "$@"
        ;;

    # ── retro ──────────────────────────────────────────────────────────────────
    retro)
        _require_sheal

        green "ctrl retro — running sheal session retrospective"
        echo ""
        dim "  Tip: accepted learnings will be saved to:"
        dim "  ~/dotfiles/instructions/_local/sheal-learnings.instructions.md"
        echo ""

        sheal retro --enrich "$@"

        echo ""
        green "Review complete. To commit accepted learnings to dotfiles:"
        echo ""
        echo "  cd ~/dotfiles"
        echo "  git add instructions/_local/ skills/_local/"
        echo "  git commit -m \"learn: [brief description]\""
        echo "  git push"
        ;;

    # ── digest ─────────────────────────────────────────────────────────────────
    digest)
        _require_sheal
        sheal digest "$@"
        ;;

    # ── cost ───────────────────────────────────────────────────────────────────
    cost)
        _require_sheal
        sheal cost "$@"
        ;;

    # ── ask ────────────────────────────────────────────────────────────────────
    ask)
        _require_sheal
        sheal ask "$@"
        ;;

    # ── learn ──────────────────────────────────────────────────────────────────
    learn)
        _require_sheal
        sheal learn "$@"
        ;;

    # ── context ────────────────────────────────────────────────────────────────
    context|ctx)
        green "Detecting context for: $(pwd)"
        echo ""
        if [[ -f "$DOTFILES/bin/detect-context.sh" ]]; then
            source "$DOTFILES/bin/detect-context.sh"
            echo "  ACTIVE_CONTEXTS=$ACTIVE_CONTEXTS"
        fi
        if [[ -f "$DOTFILES/bin/detect-client.sh" ]]; then
            source "$DOTFILES/bin/detect-client.sh"
            [[ -n "${ACTIVE_CLIENT:-}" ]] && echo "  ACTIVE_CLIENT=$ACTIVE_CLIENT"
            [[ -n "${ACTIVE_PROJECT:-}" ]] && echo "  ACTIVE_PROJECT=$ACTIVE_PROJECT"
        fi
        ;;

    # ── version ────────────────────────────────────────────────────────────────
    version|--version|-v)
        echo "ctrl+shft v$CTRL_VERSION"
        ;;

    # ── help ───────────────────────────────────────────────────────────────────
    help|--help|-h)
        echo ""
        echo "  ctrl — ctrl+shft configuration & infrastructure"
        echo "  ctrlshft.dev · github.com/arndvs/ctrlshft"
        echo ""
        echo "  Usage: ctrl <command> [options]"
        echo ""
        echo "  Infrastructure"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl check              validate symlinks + env"
        echo "  ctrl bootstrap [opts]   run bootstrap.sh [--adopt] [--minimal]"
        echo "  ctrl sync               git pull + bootstrap + reload"
        echo "  ctrl status             contexts, client, symlinks, HUD"
        echo "  ctrl context            detect & show active contexts"
        echo ""
        echo "  HUD"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl hud               start the HUD"
        echo "  ctrl hud stop          stop the HUD"
        echo "  ctrl hud status        check if running"
        echo "  ctrl hud restart       restart the HUD"
        echo "  ctrl hud logs          show HUD log (add -f to follow)"
        echo "  ctrl hud events        show recent events for current project"
        echo "  ctrl hud clear         clear events for a project"
        echo "  ctrl hud violations    show violations for a project"
        echo "  ctrl hud state         full debug state dump (JSON)"
        echo "  ctrl hud --fg          run HUD in foreground (debug mode)"
        echo "  ctrl hud open          open HUD in browser"
        echo "  ctrl hud url           print the HUD URL"
        echo ""
        echo "  Copilot Review Bridge"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl bridge            show bridge status"
        echo "  ctrl bridge start      start webhook + worker(s)"
        echo "  ctrl bridge stop       stop all bridge services"
        echo "  ctrl bridge restart    restart bridge services"
        echo "  ctrl bridge logs       show bridge log (add -f to follow)"
        echo "  ctrl bridge queue      show recent jobs"
        echo "  ctrl bridge workers    list active workers"
        echo "  ctrl bridge workspaces list PR workspaces"
        echo "  ctrl bridge replay <id> re-queue a failed job"
        echo "  ctrl bridge mint       test GitHub App token"
        echo "  ctrl bridge validate   run install checks"
        echo "  ctrl bridge url        show webhook endpoint"
        echo "  ctrl bridge --fg       run webhook in foreground"
        echo ""
        echo "  Settings"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl sync-settings      merge managed VS Code settings"
        echo "                          (--dry-run, --stable)"
        echo ""
        echo "  Client management"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl new-client         onboard a new client"
        echo "  ctrl migrate            read-only diagnostic for existing setups"
        echo "  ctrl uninstall          safely remove ctrl+shft"
        echo ""
        echo "  Credentials"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl verify-token       test-mint a GitHub App token"
        echo ""
        echo "  Session analysis (requires sheal)"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl retro              session retrospective → dotfiles"
        echo "  ctrl digest [opts]      categorized prompt digest"
        echo "  ctrl cost [opts]        token cost report"
        echo "  ctrl ask \"question\"     search across session transcripts"
        echo "  ctrl learn [opts]       manage session learnings"
        echo ""
        echo "  Other"
        echo "  ──────────────────────────────────────────────────────────────"
        echo "  ctrl version            show version"
        echo "  ctrl help               show this message"
        echo ""
        echo "  Options pass through to the underlying script."
        echo "  Example: ctrl bootstrap --adopt"
        echo "           ctrl check --ci"
        echo "           ctrl hud logs -f"
        echo ""
        ;;

    # ── unknown ────────────────────────────────────────────────────────────────
    *)
        red "Unknown command: $CMD"
        echo ""
        echo "  Run 'ctrl help' for available commands."
        exit 1
        ;;

esac

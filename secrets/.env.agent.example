# secrets/.env.agent.example — Bridge-specific agent configuration
#
# IMPORTANT: These keys are ADDITIVE. Merge them into your existing
# secrets/.env.agent (created by bootstrap), do NOT replace the file.
#   cat secrets/.env.agent.example >> secrets/.env.agent
# Then edit the appended values in secrets/.env.agent.
#
# Loaded by both webhook and worker systemd units.
#
# NOTE: GitHub App credentials (GITHUB_APP_ID, GITHUB_APP_INSTALLATION_ID,
# GITHUB_APP_PRIVATE_KEY_B64) belong in secrets/.env.secrets — worker-only,
# never sourced into interactive shells.

# Required: comma-separated list of repos the bridge will service
BRIDGE_REPO_ALLOWLIST=owner/repo

# Optional: port for the webhook receiver (default: 8765)
BRIDGE_PORT=8765

# Optional: max iterations per PR before halting (default: 3)
BRIDGE_MAX_ITERATIONS=3

# Optional: bot login for Copilot review comments
# Accepts any valid GitHub login (with or without [bot] suffix)
COPILOT_BOT_LOGIN=copilot-pull-request-reviewer[bot]

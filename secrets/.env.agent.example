# secrets/.env.agent.example — Non-sensitive bridge configuration
# Copy to .env.agent and fill in values.
# Loaded by both webhook and worker systemd units.

# Required: comma-separated list of repos the bridge will service
BRIDGE_REPO_ALLOWLIST=owner/repo

# Optional: port for the webhook receiver (default: 8765)
BRIDGE_PORT=8765

# Optional: max iterations per PR before halting (default: 3)
BRIDGE_MAX_ITERATIONS=3

# Optional: GitHub App credentials (worker only — webhook doesn't need these)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Optional: bot login for Copilot review comments
COPILOT_BOT_LOGIN=copilot-pull-request-reviewer[bot]

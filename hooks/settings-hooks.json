{
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "console.anthropic.com",
        "statsig.anthropic.com",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "sum.golang.org"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/hud-session.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/stale-branches.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/secret-guard.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/migration-guard.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/git-workflow-gate.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/plan-quality-gate.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/plan-review-phase2.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/format-check.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/typecheck.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/hud-session.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/hud-reads.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/git-post-push.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/git-post-commit.sh\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/feedback-memory-gate.py\""
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/hud-reads.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/compaction-guard.sh\""
          }
        ]
      }
    ]
  }
}
